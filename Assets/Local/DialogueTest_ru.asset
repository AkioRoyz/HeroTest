  - m_Id: 563393409024
    m_Localized: "\u041F\u0440\u0438\u0432\u0435\u0442!"
    m_Metadata:
      m_Items: []
  - m_Id: 87306511659008
    m_Localized: "\u0417\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 374196620046336
    m_Localized: "\u042F \u0445\u043E\u0447\u0443 \u0432\u0437\u044F\u0442\u044C
      \u0442\u0435\u0441\u0442\u043E\u0432\u044B\u0439 \u043A\u0432\u0435\u0441\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 374449553354752
    m_Localized: "\u042F \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0442\u0435\u0441\u0442\u043E\u0432\u044B\u0439
      \u043A\u0432\u0435\u0441\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 1659073243983872
    m_Localized: "\u0427\u0435\u043C \u044F \u043C\u043E\u0433\u0443 \u043F\u043E\u043C\u043E\u0447\u044C
      \u0442\u0435\u0431\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 1659958753832960
    m_Localized: "\u042F \u041D\u041F\u0421"
    m_Metadata:
      m_Items: []
  - m_Id: 1721857633759232
    m_Localized: "\u041F\u0440\u0438\u0432\u0435\u0442! \u042F \u0417\u0435\u043B\u0435\u043D\u044B\u0439
      \u043A\u0432\u0430\u0434\u0440\u0430\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 1722028329349120
    m_Localized: "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C
      \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u0441\u043E \u043C\u043D\u043E\u0439
      \u043E\u043F\u044F\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 1722220340391936
    m_Localized: "\u0425\u043E\u0440\u043E\u0448\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 1722338154196992
    m_Localized: "\u041F\u0440\u0438\u0432\u0435\u0442! \u042F \u041A\u0440\u0430\u0441\u043D\u044B\u0439
      \u043A\u0432\u0430\u0434\u0440\u0430\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 1722476868218880
    m_Localized: "\u0422\u044B \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0448\u044C
      \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u0441\u043E \u043C\u043D\u043E\u0439
      \u043E\u043F\u044F\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 1722603523616768
    m_Localized: "\u041F\u0440\u0430\u0432\u0434\u0430?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1773244728029184
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u043E \u0442\u0435\u0441\u0442\u0430.
      \u041F\u0435\u0440\u0432\u0430\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
      \u043D\u0430 \u043D\u0430\u043B\u0438\u0447\u0438\u0435 \u0443\u0440\u043E\u0432\u043D\u044F
      3."
    m_Metadata:
      m_Items: []
  - m_Id: 1773934699425792
    m_Localized: "\u0412\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
      \u043D\u0430 \u043D\u0430\u043B\u0438\u0447\u0438\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 1774241403711488
    m_Localized: "\u0422\u0440\u0435\u0442\u044C\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
      \u043D\u0430 \u043D\u0430\u043B\u0438\u0447\u0438\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430
      \u0432 \u0438\u043D\u0432\u0435\u043D\u0442\u0430\u0440\u0435 \u0431\u0435\u0437
      \u043E\u0442\u0432\u0435\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 1775008302837760
    m_Localized: "\u0423 \u043C\u0435\u043D\u044F \u043D\u0435\u0442 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 1775167849967616
    m_Localized: "\u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u043F\u0440\u0435\u0434\u043C\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 1775282115391488
    m_Localized: "\u0422\u0435\u0441\u0442 \u043E\u043A\u043E\u043D\u0447\u0435\u043D."
